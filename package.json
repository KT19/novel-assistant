{
  "name": "novel-assistant",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "uv run python -m backend.server",
    "build:backend": "node scripts/build-backend-sidecar.mjs",
    "check:tauri": "node scripts/check-tauri-prereqs.mjs",
    "seed:demo": "node scripts/seed-demo.mjs",
    "tauri": "tauri",
    "tauri:dev": "npm run check:tauri && npm run build:backend && node scripts/tauri-dev.mjs",
    "tauri:build": "npm run check:tauri && npm run build:backend && tauri build",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "lint": "tsc --noEmit -p tsconfig.app.json --pretty false && tsc --noEmit -p tsconfig.node.json --pretty false",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mantine/core": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "@tauri-apps/api": "^2.10.1",
    "@vitejs/plugin-react": "^4.6.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
