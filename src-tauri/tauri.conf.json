{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "言の葉",
  "version": "0.1.0",
  "identifier": "com.local.novel-assistant",
  "build": {
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "言の葉",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/novel-assistant-backend"
    ]
  }
}
